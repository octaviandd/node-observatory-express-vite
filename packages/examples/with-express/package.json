{
  "name": "with-express",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "index.ts",
  "scripts": {
    "build": "npm run build:deps && tsc",
    "build:deps": "cd ../../api && npm run build && cd ../express  npm run build && ../ui npm run build",
    "dev": "node --trace-warnings --trace-uncaught -r ts-node/esm index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf node_modules package-lock.json",
    "dev-all": "nodemon --watch ../../api/dist --watch ../../express/dist --watch ../../ui/dist -e js,json --exec 'node -r ts-node/register index.ts'",
    "stress": "node -r ts-node/register stress.ts",
    "stress:heavy": "node -r ts-node/register stress.ts --count 200 --parallel 10",
    "stress:extreme": "node -r ts-node/register stress.ts --count 500 --parallel 20"
  },
  "author": "octavian david",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@node-observatory/api": "*",
    "@node-observatory/express": "*",
    "@node-observatory/ui": "*",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "mysql2": "^3.14.0",
    "node-cache": "^5.1.2",
    "redis": "^4.7.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
