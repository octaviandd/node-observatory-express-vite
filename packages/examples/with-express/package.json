{
  "name": "with-express",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "NODE_ENV=development nodemon --watch ../../api/dist --watch ../../express/dist -e js,json --delay 2 --exec 'node -r ts-node/register index.ts'",
    "start": "node dist/index.js",
    "clean": "rm -rf node_modules package-lock.json",
    "stress": "node -r ts-node/register stress.ts",
    "stress:heavy": "node -r ts-node/register stress.ts --count 200 --parallel 10",
    "stress:extreme": "node -r ts-node/register stress.ts --count 500 --parallel 20",
    "test:node-cache": "node -r ts-node/register tests/node-cache.ts",
    "test:redis": "node -r ts-node/register tests/redis.ts",
    "test:ioredis": "node -r ts-node/register tests/ioredis.ts",
    "test:keyv": "node -r ts-node/register tests/keyv.ts",
    "test:pino": "node -r ts-node/register tests/pino.ts",
    "test:winston": "node -r ts-node/register tests/winston.ts",
    "test:bunyan": "node -r ts-node/register tests/bunyan.ts",
    "test:log4js": "node -r ts-node/register tests/log4js.ts",
    "test:loglevel": "node -r ts-node/register tests/loglevel.ts",
    "test:signale": "node -r ts-node/register tests/signale.ts",
    "test:nodemailer": "node -r ts-node/register tests/nodemailer.ts",
    "test:pusher": "node -r ts-node/register tests/pusher.ts",
    "test:ably": "node -r ts-node/register tests/ably.ts",
    "test:bull": "node -r ts-node/register tests/bull.ts",
    "test:node-cron": "node -r ts-node/register tests/node-cron.ts",
    "test:node-schedule": "node -r ts-node/register tests/node-schedule.ts",
    "test:mysql2": "node -r ts-node/register tests/mysql2.ts",
    "test:knex": "node -r ts-node/register tests/knex.ts",
    "test:sequelize": "node -r ts-node/register tests/sequelize.ts",
    "test:mongoose": "node -r ts-node/register tests/mongoose.ts",
    "test:http": "node -r ts-node/register tests/http.ts"
  },
  "author": "octavian david",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@node-observatory/api": "*",
    "@node-observatory/express": "*",
    "@node-observatory/ui": "*",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "mysql2": "^3.14.0",
    "node-cache": "^5.1.2",
    "redis": "^4.7.0",
    "winston": "^3.17.0"
  },
  "optionalDependencies": {
    "ably": ">=2.0.0",
    "agenda": ">=5.0.0",
    "bull": ">=4.0.0",
    "bunyan": ">=1.8.0",
    "ioredis": ">=5.0.0",
    "keyv": ">=5.0.0",
    "knex": ">=3.0.0",
    "log4js": ">=6.0.0",
    "loglevel": ">=1.0.0",
    "mongoose": ">=8.0.0",
    "node-cron": ">=3.0.0",
    "node-schedule": ">=2.0.0",
    "nodemailer": ">=6.0.0",
    "pino": ">=9.0.0",
    "pusher": ">=5.0.0",
    "sequelize": ">=6.0.0",
    "signale": ">=1.4.0",
    "undici": ">=7.0.0"
  },
  "devDependencies": {
    "vite": "*",
    "@types/bunyan": "^1.8.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node-cron": "^3.0.11",
    "@types/node-schedule": "^2.1.7",
    "@types/nodemailer": "^6.4.17",
    "@types/signale": "^1.4.7",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
