{
  "compilerOptions": {
    "target": "es2024",
    "module": "commonjs",
    "outDir": "dist",
    "declarationDir": "dist",
    "baseUrl": ".",
    "declaration": true,
    "strict": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "paths": {
      "undici-types": ["./node_modules/undici-types/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "index.ts", "types.d.ts"],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "index.esm.ts"]
}