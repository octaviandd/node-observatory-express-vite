{
  "openapi": "3.0.0",
  "info": {
    "title": "Observatory API",
    "version": "1.0.0",
    "description": "Monitoring and observability API for Node.js applications"
  },
  "servers": [
    {
      "url": "",
      "description": "API Server"
    }
  ],
  "components": {
    "schemas": {
      "Period": {
        "type": "string",
        "enum": [
          "1h",
          "24h",
          "7d",
          "14d",
          "30d"
        ]
      },
      "IndexType": {
        "type": "string",
        "enum": [
          "instance",
          "group"
        ]
      },
      "BaseFilters": {
        "type": "object",
        "properties": {
          "offset": {
            "type": "integer",
            "default": 0
          },
          "limit": {
            "type": "integer",
            "default": 20
          },
          "period": {
            "$ref": "#/components/schemas/Period"
          },
          "query": {
            "type": "string"
          },
          "isTable": {
            "type": "boolean"
          },
          "index": {
            "$ref": "#/components/schemas/IndexType"
          },
          "key": {
            "type": "string"
          }
        }
      },
      "Exception": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "exception"
            ]
          },
          "content": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "unhandledRejection",
                  "uncaughtException"
                ]
              },
              "stack": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "request_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "job_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "schedule_id": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "ListResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "string"
          }
        }
      },
      "GraphResponse": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
