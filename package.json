{
  "name": "node-observatory",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "packages/*",
    "packages/examples/*"
  ],
  "scripts": {
    "build:api": "npm run build -w @node-observatory/api",
    "build:ui": "npm run build -w @node-observatory/ui",
    "build:express": "npm run build -w @node-observatory/express",
    "build:turbo": "turbo run build",
    "dev:turbo": "turbo run dev",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "publish:packages": "npm publish --workspaces --access public"
  },
  "devDependencies": {
    "turbo": "^2.8.20",
    "typescript": "^5.0.0"
  }
}
