{
  "name": "node-observatory",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*",
    "packages/examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build -w @node-observatory/api",
    "build:ui": "npm run build -w @node-observatory/ui",
    "build:express": "npm run build -w @node-observatory/express",
    
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "npm run dev -w @node-observatory/api",
    "dev:ui": "npm run dev -w @node-observatory/ui",
    "dev:example": "npm run dev -w with-express",
    "dev:all:cjs": "concurrently \"npm run dev -w @node-observatory/ui\" \"npm run dev-cjs -w @node-observatory/api\" \"npm run dev -w @node-observatory/express\" \"npm run dev-all -w with-express\"",
    "dev:all:esm": "concurrently \"npm run dev -w @node-observatory/ui\" \"npm run dev-esm -w @node-observatory/api\" \"npm run dev -w @node-observatory/express\" \"npm run dev-all -w with-express\"",
    
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    
    "typecheck": "npm run typecheck --workspaces --if-present",
    
    "publish:packages": "npm publish --workspaces --access public"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "concurrently": "^8.0.0"
  }
}