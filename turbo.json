{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "dev-cjs": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "dev-esm": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "dev-all": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "lint": {
      "cache": false
    }
  }
}
